{
	"info": {
		"_postman_id": "ali-unal-yemekimnerede",
		"name": "YEMEKİMNEREDE - Ali Ünal",
		"description": "Kullanıcı kaydı, girişi ve profil yönetimi endpointleri",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Kayıt Olma",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"ad\": \"Ali\",\n  \"soyad\": \"Ünal\",\n  \"email\": \"ali@ornek.com\",\n  \"sifre\": \"Gizli123!\",\n  \"telefon\": \"+905551234567\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/v1/auth/register",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "auth", "register"]
				},
				"description": "Yeni kullanıcı kaydı oluşturur"
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const res = pm.response.json();",
							"if (res.kullanici && res.kullanici._id) {",
							"  pm.collectionVariables.set('kullaniciId', res.kullanici._id);",
							"}",
							"if (res.token) {",
							"  pm.collectionVariables.set('token', res.token);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "2. Giriş Yapma",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"ali@ornek.com\",\n  \"sifre\": \"Gizli123!\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/v1/auth/login",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "auth", "login"]
				},
				"description": "Kullanıcı girişi yapar ve JWT token döner"
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const res = pm.response.json();",
							"if (res.token) {",
							"  pm.collectionVariables.set('token', res.token);",
							"}",
							"if (res.kullanici && res.kullanici._id) {",
							"  pm.collectionVariables.set('kullaniciId', res.kullanici._id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "3. Profil Görüntüleme",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/v1/users/{{kullaniciId}}",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "users", "{{kullaniciId}}"]
				},
				"description": "Kullanıcı profil bilgilerini getirir"
			}
		},
		{
			"name": "4. Profil Güncelleme",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"ad\": \"Ali\",\n  \"soyad\": \"Ünal\",\n  \"telefon\": \"+905559876543\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/v1/users/{{kullaniciId}}",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "users", "{{kullaniciId}}"]
				},
				"description": "Kullanıcı profil bilgilerini günceller"
			}
		},
		{
			"name": "5. Şifre Güncelleme",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"mevcutSifre\": \"Gizli123!\",\n  \"yeniSifre\": \"YeniGizli456!\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/v1/users/{{kullaniciId}}/password",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "users", "{{kullaniciId}}", "password"]
				},
				"description": "Kullanıcı şifresini günceller"
			}
		},
		{
			"name": "6. Adres Ekleme",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"baslik\": \"Ev\",\n  \"adres\": \"Atatürk Caddesi No:5\",\n  \"sehir\": \"İstanbul\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/v1/users/{{kullaniciId}}/addresses",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "users", "{{kullaniciId}}", "addresses"]
				},
				"description": "Kullanıcıya yeni adres ekler"
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const res = pm.response.json();",
							"if (res.adresler && res.adresler.length > 0) {",
							"  const sonAdres = res.adresler[res.adresler.length - 1];",
							"  pm.collectionVariables.set('adresId', sonAdres._id);",
							"  console.log('adresId otomatik set edildi:', sonAdres._id);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			]
		},
		{
			"name": "7. Adres Silme",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/v1/users/{{kullaniciId}}/addresses/{{adresId}}",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "users", "{{kullaniciId}}", "addresses", "{{adresId}}"]
				},
				"description": "Kullanıcının belirli bir adresini siler"
			}
		},
		{
			"name": "8. Hesap Silme",
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/v1/users/{{kullaniciId}}",
					"host": ["{{baseUrl}}"],
					"path": ["v1", "users", "{{kullaniciId}}"]
				},
				"description": "Kullanıcı hesabını siler - EN SON ÇALIŞTIR"
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://yemekimnerde-production.up.railway.app",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		},
		{
			"key": "kullaniciId",
			"value": "",
			"type": "string"
		},
		{
			"key": "adresId",
			"value": "",
			"type": "string"
		}
	]
}
